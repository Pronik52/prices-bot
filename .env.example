# ---- PostgreSQL ----
DB_PASSWORD=change_me
# Полный DSN. Внутри docker-compose host = имя сервиса "postgres".
DATABASE_URL=postgresql+psycopg2://app:change_me@postgres:5432/price_tracker

# ---- Redis / Celery ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ---- API ----
API_BASE_URL=http://api:8000
API_HOST=0.0.0.0
API_PORT=8000
# Общий секрет для внутренней аутентификации бот<->API
INTERNAL_API_TOKEN=dev-internal-token

# ---- Telegram ----
BOT_TOKEN=123456:PUT_YOUR_TOKEN_HERE

# ---- Общее ----
LOG_LEVEL=INFO
# Интервал проверки цен планировщиком, в секундах (по умолчанию раз в час)
PRICE_CHECK_INTERVAL=3600

# ---- Wildberries ----
# Скидка при оплате WB Кошельком, %. WB не отдаёт её в API — применяем сами.
# Если WB изменит промо (сейчас 3%) — поправьте здесь без пересборки кода.
WB_WALLET_DISCOUNT_PERCENT=3

# ---- Прокси для парсеров (опционально, список через запятую) ----
# PROXY_LIST=http://user:pass@1.2.3.4:8000,http://user:pass@5.6.7.8:8000
PROXY_LIST=
